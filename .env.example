# Copy to `.env` and fill in to enable real Layer-2 topology.
# Without any of these, the app falls back to the logical (hub-and-spoke) view.
# Pick ONE provider. SNMP is vendor-neutral and tried first.

# ============================================================================
# Server security & behavior (all optional; safe defaults)
# ============================================================================
# The server listens on 127.0.0.1 by default (run.sh). To expose it on the LAN:
#   HOST=0.0.0.0 ./run.sh        <- pair with NDM_API_TOKEN below!

# Require this token on /api/scan* (X-API-Token header, or ?token= — the widget
# forwards it automatically when opened as http://host:8000/?token=VALUE).
NDM_API_TOKEN=

# Origins allowed to call the API cross-origin (for embedding the widget on
# another site). Default: none (same-origin only). "*" restores open CORS.
# Example: NDM_CORS_ORIGINS=https://my-site.example
NDM_CORS_ORIGINS=

# Restrict what ?target= may scan (comma-separated CIDRs). Default: unrestricted.
# The auto-detected local LAN is always allowed.
# Example: NDM_ALLOWED_TARGETS=192.168.0.0/16,10.0.0.0/8
NDM_ALLOWED_TARGETS=

# Scan-history database for NEW/missing-device detection.
# Default: <project>/scan_history.db. Set to "off" to disable persistence.
NDM_DB=

# Override the auto-detected subnet for the default scan (rarely needed).
NDM_SUBNET=

# ============================================================================
# Provider 1 — SNMP (vendor-neutral: Cisco, Aruba, Netgear, MikroTik, UniFi, …)
# Requires net-snmp CLI tools:  brew install net-snmp   |   apt install snmp
# and SNMP enabled on your managed switches with a read community string.
# ============================================================================
# Read community string (activates the SNMP provider). v3 not yet supported.
SNMP_COMMUNITY=
# Optional: comma-separated switch IPs to poll. If blank, every discovered host is
# probed and SNMP responders are used automatically.
SNMP_TARGETS=
SNMP_VERSION=2c
SNMP_TIMEOUT=2

# ============================================================================
# Provider 2 — UniFi controller (optional convenience for UniFi networks)
# ============================================================================

# Base URL of the controller. For UniFi OS (UDM/UDR/Cloud Key G2) this is usually the
# gateway itself, e.g. https://10.1.1.1  (no trailing slash, https).
UNIFI_URL=https://10.1.1.1

# --- Preferred: official API key (Network 10.1.84+) -------------------------
# Create in the Network app: Settings -> Control Plane -> Integrations  (a.k.a. the
# "API Keys" tab). Stateless, no MFA, scoped to the creating admin's permissions.
UNIFI_API_KEY=

# --- Fallback: local admin (older controllers without API keys) -------------
# Leave blank if using UNIFI_API_KEY above.
UNIFI_USERNAME=
UNIFI_PASSWORD=

# Site name as it appears in the controller (default for most setups).
UNIFI_SITE=default

# Controllers ship self-signed certs; leave false unless you've installed a trusted cert.
UNIFI_VERIFY_TLS=false
